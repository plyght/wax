 pub fn validate_package_name(name: &str) -> Result<()> {
     if name.is_empty() {
-        return Err(WaxError::InvalidInput("Package name cannot be empty".to_string()));
+        return Err(WaxError::InvalidInput(
+            "Package name cannot be empty".to_string(),
